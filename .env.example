# Copie en .env et remplis

# ── Obligatoire en production ──
FLASK_SECRET_KEY=change_moi_avec_une_longue_chaine_aleatoire

# ── Serveur ──
HOST=0.0.0.0
PORT=8080
LOCAL_IP=192.168.13.138
APP_URL=https://davidramenecrepe.fr

# ── Horaires ──
RESET_HOUR=14
VOTE_OPEN_HOUR=9

# ── CORS (uniquement si front séparé du back, ex. GitHub Pages) ──
# ALLOWED_ORIGINS=https://davidramenecrepe.fr,https://www.davidramenecrepe.fr
DEBUG=false
SEND_PIN_EMAILS=false
SESSION_COOKIE_SECURE=true

# ── Gmail — mot de passe d'application :
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ton_email@gmail.com
SMTP_PASSWORD=mot_de_passe_application_16_caracteres
EMAIL_FROM=ton_email@gmail.com
